{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/shared": ["packages/shared/src/index.ts"],
      "@workspace/messaging/*": ["services/messaging/src/*"],
      "@workspace/api/*": ["apps/api/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
